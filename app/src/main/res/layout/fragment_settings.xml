<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:id="@+id/settings_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Kurucu & Uygulama Bilgisi ── -->
        <TextView
            android:id="@+id/settings_creator_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nebi Özkan"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/settings_app_purpose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ücretsiz ve reklamsız video indirici"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="24dp" />

        <!-- ── Karanlık Mod (DOKUNULMADI) ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#1A1A1A"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Karanlık Mod"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF" />

                <Switch
                    android:id="@+id/settings_dark_mode_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Parmak İzi (DOKUNULMADI) ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#1A1A1A"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Parmak İzi Doğrulama"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="İndirilen videoları korur"
                        android:textSize="12sp"
                        android:textColor="#888888" />

                </LinearLayout>

                <Switch
                    android:id="@+id/settings_fingerprint_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Temalar (yenilendi) ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEMALAR"
            android:textSize="11sp"
            android:textColor="#666666"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/settings_theme_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#1A1A1A"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/settings_theme_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Temalar"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/settings_current_theme_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="16dp" />

                <!-- Siyah İnci -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/theme_btn_black_pearl"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Siyah İnci"
                    app:cornerRadius="8dp"
                    android:layout_marginBottom="8dp" />

                <!-- Gece Mavisi -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/theme_btn_midnight_blue"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Gece Mavisi"
                    app:cornerRadius="8dp"
                    android:layout_marginBottom="8dp" />

                <!-- Zümrüt -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/theme_btn_emerald"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Zümrüt"
                    app:cornerRadius="8dp"
                    android:layout_marginBottom="8dp" />

                <!-- Yakut -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/theme_btn_ruby"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Yakut"
                    app:cornerRadius="8dp"
                    android:layout_marginBottom="8dp" />

                <!-- Nebi Özkan Özel -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/theme_btn_nebi_ozkan"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Nebi Özkan Özel"
                    app:cornerRadius="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
