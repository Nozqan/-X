<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="12dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">

    <RadioButton
        android:id="@+id/rbSelected"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/orange_accent"
        android:clickable="false"
        android:focusable="false" />

    <TextView
        android:id="@+id/tvQualityBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        tools:text="1080p (FHD) / Mp4" />

    <View
        android:layout_width="1dp"
        android:layout_height="16dp"
        android:layout_marginHorizontal="8dp"
        android:background="#333333" />

    <TextView
        android:id="@+id/tvQualitySize"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/orange_accent"
        android:textSize="14sp"
        android:textStyle="bold"
        tools:text="1.2 GB" />

    <TextView
        android:id="@+id/tvQualityLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        tools:text="Yüksek Kalite" />

</LinearLayout>
